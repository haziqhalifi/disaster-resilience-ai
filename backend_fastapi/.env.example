# Copy this file to backend_fastapi/.env and replace placeholder values.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_REPORT_MEDIA_BUCKET=report-media

# Optional auth settings used by some local/dev flows
# DISASTER_SECRET_KEY=generate-a-random-secret
# DISASTER_TOKEN_EXPIRE_MINUTES=10080

# OpenAI assistant chat
OPENAI_API_KEY=your-openai-api-key
OPENAI_ASSISTANT_ID=your-openai-assistant-id

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Admin website credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_JWT_SECRET=replace-with-a-long-random-secret

# Official disaster feed
NADMA_DISASTERS_API_URL=https://mydims.nadma.gov.my/api/disasters
NADMA_DISASTERS_API_TOKEN=your-nadma-api-token

# SMS provider: mocean | vonage | easysendsms
SMS_PROVIDER=mocean

# Twilio fallback
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-sender-number
# TWILIO_FROM_NUMBER=legacy-twilio-sender-number

# Mocean
MOCEAN_API_KEY=your-mocean-api-key-or-token
MOCEAN_API_SECRET=your-mocean-api-secret

# Vonage
VONAGE_API_KEY=your-vonage-api-key
VONAGE_API_SECRET=your-vonage-api-secret

# EasySendSMS
EASYSENDSMS_USERNAME=your-easysendsms-username
EASYSENDSMS_PASSWORD=your-easysendsms-password
EASYSENDSMS_API_KEY=your-easysendsms-api-key

# Demo SMS safeguards
DEMO_PHONE=
SMS_DEMO_MODE=true